# Core paths
ARTICLE_ANALYSIS_CORPUS=Forskning
ARTICLE_ANALYSIS_RUNS_DIR=runs

# Azure OpenAI / OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_REASONING_EFFORT=low
OPENAI_API_KEY=

# Parsing and OCR
GROBID_BASE_URL=http://localhost:8070
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=

# Scholarly metadata APIs (used in M3 enrichment)
# OpenAlex = citation graph + disambiguated authors. API key required since Feb 2026
# (free key = $1/day ~= 100k credits; single-lookups free, list/search/PDF cost more).
# The old mailto/polite-pool is gone, so no OpenAlex email is used anymore.
OPENALEX_API_KEY=
# Crossref = DOI resolution + bibliographic metadata. No key; email enables the polite pool.
CROSSREF_EMAIL=
# Semantic Scholar = optional citation context / embeddings.
SEMANTIC_SCHOLAR_API_KEY=
# Unpaywall = legal open-access full-text links per DOI. Email is required by the API.
UNPAYWALL_EMAIL=

# Optional local pricing override
AI_MODEL_PRICING_JSON=

